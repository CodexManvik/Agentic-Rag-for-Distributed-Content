# ============================================================================
# OLLAMA MODEL CONFIGURATION (Optimized for 4GB VRAM + Intel i5-12450H)
# ============================================================================
# llama3.2:3b is OPTIMAL (uses ~2-3GB VRAM, ~6GB RAM total)
# Alternatives if memory is tight: phi:2.7b, orca-mini:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# ============================================================================
# VECTOR DATABASE CONFIGURATION
# ============================================================================
CHROMA_COLLECTION_NAME=knowledge_base
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ============================================================================
# RETRIEVAL OPTIMIZATION (Tuned for 4GB VRAM)
# ============================================================================
RETRIEVAL_TOP_K=4
RETRIEVAL_PER_QUERY_K=3
RETRIEVAL_BM25_K=5
HYBRID_RETRIEVAL_ENABLED=true
BM25_CACHE_ENABLED=true
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
RETRIEVAL_MIN_SCORE=0.65
RETRIEVAL_MIN_CHUNKS=2
RETRIEVAL_MIN_SOURCE_DIVERSITY=1
RETRIEVAL_HARD_QUERY_MIN_SCORE_BOOST=0.08
RETRIEVAL_HARD_QUERY_MIN_SOURCE_DIVERSITY=3
RETRIEVAL_QUERY_OVERLAP_MIN=0.10
RETRIEVAL_ENTITY_OVERLAP_MIN=0.10
RERANK_ENABLED=true
LOW_LATENCY_SKIP_OVERLAP_CHECK=true

# ============================================================================
# DEBUGGING
# ============================================================================
DEBUG_TRACE_ENABLED=false
MAX_RETRIEVAL_RETRIES=0
MAX_VALIDATION_RETRIES=0

# ============================================================================
# RUNTIME PROFILE (Low Latency = Best for i5-12450H)
# ============================================================================
RUNTIME_PROFILE=low_latency

# ============================================================================
# LLM GENERATION PARAMETERS
# ============================================================================
MODEL_TEMPERATURE=0.3
MODEL_TOP_P=0.85
MODEL_TOP_K=15
MODEL_MIN_P=0.0
MODEL_PRESENCE_PENALTY=0.0
MODEL_REPETITION_PENALTY=1.1

# ============================================================================
# REQUEST TIMEOUTS (Increased for i5-12450H CPU speed)
# ============================================================================
MODEL_REQUEST_TIMEOUT_SECONDS=60
LOW_LATENCY_MODEL_REQUEST_TIMEOUT_SECONDS=60
PLANNER_REQUEST_TIMEOUT_SECONDS=8
LOW_LATENCY_PLANNER_REQUEST_TIMEOUT_SECONDS=8
REFORMULATION_REQUEST_TIMEOUT_SECONDS=8
LOW_LATENCY_REFORMULATION_REQUEST_TIMEOUT_SECONDS=8
SYNTHESIS_REQUEST_TIMEOUT_SECONDS=180
LOW_LATENCY_SYNTHESIS_REQUEST_TIMEOUT_SECONDS=180

# ============================================================================
# OUTPUT TOKEN LIMITS (Constrained for memory)
# ============================================================================
LOW_LATENCY_MAX_OUTPUT_TOKENS=256
MODEL_MAX_OUTPUT_TOKENS=512
LOW_LATENCY_PLANNER_MAX_OUTPUT_TOKENS=48
PLANNER_MAX_OUTPUT_TOKENS=64
LOW_LATENCY_REFORMULATION_MAX_OUTPUT_TOKENS=64
REFORMULATION_MAX_OUTPUT_TOKENS=96
LOW_LATENCY_SYNTHESIS_MAX_OUTPUT_TOKENS=256
SYNTHESIS_MAX_OUTPUT_TOKENS=256
MODEL_STOP_SEQUENCES=</think>,```,\n\nHuman:,\n\nUSER QUESTION:

# ============================================================================
# CHUNKING CONFIGURATION (Token-aware for LLM context windows)
# ============================================================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
CHUNK_SIZE_TOKENS=512
TOKEN_ENCODING_MODEL=cl100k_base

# ============================================================================
# STARTUP & SOURCES
# ============================================================================
FAIL_FAST_ON_STARTUP=true
ALLOWED_SOURCE_DOMAINS=support.atlassian.com,confluence.atlassian.com,docs.langchain.com,python.langchain.com,langchain.com,atlassian.com,www.atlassian.com,www.langchain.com,arxiv.org,cdn.openai.com,openai.com,www.openai.com,anthropic.com,www.anthropic.com,ai.google.dev,developers.google.com,research.google,paperswithcode.com,langchain-ai.github.io,github.io,github.com,www.github.com
PUBLIC_SOURCES_ONLY=true
