OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
CHROMA_COLLECTION_NAME=knowledge_base
CHROMA_PERSIST_DIRECTORY=./chroma_data
RETRIEVAL_TOP_K=4
RETRIEVAL_PER_QUERY_K=4
RETRIEVAL_BM25_K=6
HYBRID_RETRIEVAL_ENABLED=true
BM25_CACHE_ENABLED=true
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_MIN_CHUNKS=3
RETRIEVAL_MIN_SOURCE_DIVERSITY=2
RERANK_ENABLED=true
DEBUG_TRACE_ENABLED=false
MAX_RETRIEVAL_RETRIES=1
MAX_VALIDATION_RETRIES=1
RUNTIME_PROFILE=balanced
MODEL_TEMPERATURE=1.0
MODEL_TOP_P=0.95
MODEL_TOP_K=20
MODEL_MIN_P=0.0
MODEL_PRESENCE_PENALTY=1.5
MODEL_REPETITION_PENALTY=1.0
MODEL_REQUEST_TIMEOUT_SECONDS=18
MODEL_MAX_OUTPUT_TOKENS=420
MODEL_STOP_SEQUENCES=
FAIL_FAST_ON_STARTUP=true
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
ALLOWED_SOURCE_DOMAINS=support.atlassian.com,confluence.atlassian.com,docs.langchain.com,python.langchain.com,langchain.com,atlassian.com,www.atlassian.com,www.langchain.com
PUBLIC_SOURCES_ONLY=true
