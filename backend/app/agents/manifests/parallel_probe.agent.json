{
  "name": "parallel_probe",
  "version": "1.0.0",
  "description": "Parallel workflow for normalize_query and planning.",
  "inputs": {
    "query": { "type": "string", "required": true },
    "original_query": { "type": "string", "required": true }
  },
  "outputs": {
    "query": { "type": "string" },
    "sub_queries": { "type": "array" },
    "trace": { "type": "array" }
  },
  "execution": {
    "type": "workflow",
    "execution_mode": "parallel",
    "workflow": [
      { "agent": "normalize_query" },
      { "agent": "planning" }
    ]
  }
}
