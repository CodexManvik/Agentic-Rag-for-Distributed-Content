{
  "name": "ollama-chat-desktop",
  "version": "1.0.0",
  "description": "Desktop chat application for Agentic RAG with Ollama",
  "main": "dist-electron/main/main.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run build:electron && wait-on http://localhost:5173 && electron .\"",
    "build:electron": "esbuild src/main/main.ts --bundle --external:electron --outfile=dist-electron/main/main.js --format=esm --platform=node && esbuild src/preload/preload.ts --bundle --outfile=dist-electron/preload/preload.js --format=esm --platform=node",
    "build": "npm run build:electron && vite build && electron-builder",
    "build:win": "npm run build:electron && vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.472.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^8.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aura.app",
    "productName": "Aura",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/assets/icon.ico",
      "uninstallerIcon": "public/assets/icon.ico",
      "installerHeaderIcon": "public/assets/icon.ico"
    },
    "directories": {
      "buildResources": "public/assets"
    }
  }
}
